#include <iostream>
using namespace std;

int main() {
    int n = 5; 

    for (int i = n; i >= 1; i--) {
      
        for (int j = 1; j < i; j++) {
            cout << "  "; 
        }

        for (int k = i; k <= n; k++) {
            cout << k << " ";
        }

        for (int A = n - 1; A >= i; A--) {
            cout << A << " ";
        }

        cout << endl;
    }

    return 0;
}

