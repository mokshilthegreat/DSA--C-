Q4
#include <iostream>
using namespace std;

int main() {

    int arr[3][3] = {
        {2, 7, 1},
        {4, 5, 6},
        {9, 8, 3}
    };

    int row, col;
    int rowSum = 0, colSum = 0;

    cout << "Enter row number: ";
    cin >> row;

    cout << "Elements of row " << row << ": ";

    for(int j = 0; j < 3; j++) {
        cout << arr[row][j] << " ";

        if(j < 2) {
            cout << "+ ";
        }

        rowSum += arr[row][j];
    }

    cout << endl;
    cout << "The sum of a row " << row << " : " << rowSum << endl;

    // ---------------------------
    cout << "\nEnter column number: ";
    cin >> col;

    cout << "Elements of column " << col << ": ";

    for(int i = 0; i < 3; i++) {
        cout << arr[i][col] << " ";

        if(i < 2) {
            cout << "+ ";
        }

        colSum += arr[i][col];
    }

    cout << endl;
    cout << "The sum of column " << col << " : " << colSum << endl;

    return 0;
}