Q1
#include <iostream>
using namespace std;

int main() {
    int n;

    cout << "Enter array size: ";
    cin >> n;

    int a[n];

    // Input
    for(int i = 0; i < n; i++) {
        cout << "a[" << i << "] = ";
        cin >> a[i];
    }

    // Output (negative elements)
    cout << "Negative elements are: ";

    for(int i = 0; i < n; i++) {
        if(a[i] < 0) {
            cout << a[i] << " ";
        }
    }

    return 0;
}

